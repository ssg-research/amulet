# Content-addressed model checkpoint cache (see common/models.py, and E5's own in
# experiments/e5_textbadnets/llm_backdoor_common.py). Regenerated by any run; never
# committed.
.model_cache/

# E5's ONION perplexity cache, keyed by input text (llm_backdoor_common.cached_purify).
# The trailing glob covers the per-seed variants a parallel sweep creates.
.onion_cache/
.onion_cache_*/

__pycache__/

# The repository root .gitignore excludes `experiments/`, `plots/` and `tables/`
# (they name throwaway scratch dirs at the top level). Under `artifact/` those
# same names are shipped deliverables, so re-include them here. Negations must
# name the directory itself: git never descends into an excluded directory, so
# `!experiments/**` alone would not be enough.
!experiments/
!plots/
!tables/
